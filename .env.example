# Git It environment configuration
# Copy this file to `.env` and fill only what your scenario needs.

# -----------------------------------------------------------------------------
# LLM providers
# -----------------------------------------------------------------------------

# Required for commit analysis, case-study generation, case-study regeneration,
# GitHub discussion summarization, and the Ask tab LLM.
ANTHROPIC_API_KEY=

# Required only for embedding-backed semantic search in Ask.
# Without it, Ask still works with regular read-only repository tools, but
# semantic search (`search_similar_commits`) is disabled.
# Embeddings are generated during commit analysis; old analyses are not
# automatically backfilled if this is added later.
OPENAI_API_KEY=

# Optional: embedding model override. Keep the default unless you know you need
# another LiteLLM-supported embedding model.
EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# GitHub API enrichment
# -----------------------------------------------------------------------------

# Optional: enables GitHub API enrichment where available: repository stars,
# language breakdown, PR/issues context for commit analysis, and discussion
# evidence. This does NOT enable private repository cloning; ingestion is focused
# on public GitHub HTTPS repositories.
GITHUB_TOKEN=

# Optional advanced GitHub discussion evidence tuning. Values must be integers.
DISCUSSION_MIN_ENGAGEMENT_SCORE=5
DISCUSSION_MIN_REPLY_COUNT=3
DISCUSSION_MAX_SUMMARIZED=20
DISCUSSION_PAGE_SIZE=50
DISCUSSION_MAX_PAGES=10

# Optional advanced GitHub release/advisory evidence limits. Values must be integers.
RELEASE_MAX_SUMMARIZED=10
ADVISORY_MAX_SUMMARIZED=10

# -----------------------------------------------------------------------------
# API access control
# -----------------------------------------------------------------------------

# Optional: protect write/cost endpoints with Authorization: Bearer <token>.
# Leave blank for normal local dashboard usage. The current static dashboard does
# not send this header, so setting this is intended for direct API/shared deployments.
GIT_IT_API_KEY=

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# Optional: custom data root. Leave blank for the default project-local data dir:
# .data/git-it/ingestion/
# Note: `git-it serve` roots data at the current working directory; this variable
# is mainly useful when running the ASGI app directly or integrating the API/MCP.
GIT_IT_DATA_DIR=

# Optional: PostgreSQL backend. Leave blank for local SQLite.
# Example: DATABASE_URL=postgresql://gitit:I2E4@localhost:5432/gitit
# If set to a postgres/postgresql URL, Git It expects PostgreSQL to be reachable
# and will not silently fall back to SQLite.
DATABASE_URL=

# Optional: maximum characters of root README/CHANGELOG text included as project
# document context for LLM prompts. Value must be an integer.
PROJECT_DOC_MAX_CHARS=2000